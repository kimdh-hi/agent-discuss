{
  "name": "@agent-discuss/be",
  "version": "0.1.0",
  "private": true,
  "description": "agent-discuss - 워크스페이스 기반 멀티 에이전트 PoC (NestJS + LangChain.js)",
  "scripts": {
    "build": "nest build",
    "dev:server": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config test/jest-e2e.json",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.1",
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/openai": "^1.4.7",
    "@langchain/textsplitters": "^1.0.1",
    "@mikro-orm/core": "^6.6.14",
    "@mikro-orm/nestjs": "^6.1.2",
    "@mikro-orm/postgresql": "^6.6.14",
    "@mikro-orm/sqlite": "^6.6.14",
    "@napi-rs/canvas": "^0.1.65",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "cheerio": "^1.2.0",
    "fflate": "^0.8.2",
    "pdfjs-dist": "^4.10.38",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.0",
    "@swc/jest": "^0.2.37",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22"
  },
  "jest": {
    "moduleFileExtensions": ["js", "mjs", "json", "ts"],
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j|mj)s$": "@swc/jest"
    },
    "transformIgnorePatterns": []
  }
}
