# 서버
PORT=4070

# 인증 (PoC dev 로그인)
JWT_SECRET=rai-agent-dev-secret-change-me
JWT_EXPIRES_IN=7d

# DB (sqlite) — 파일 경로 또는 ":memory:"
DATABASE_PATH=./data/rai-agent.sqlite

# LLM (현재 채팅/토론 경로는 LangChain ChatOpenAI 사용)
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# RAG (실제 파이프라인: pgvector + gotenberg)
# 인프라: npm run infra:up (docker compose: rag-postgres/gotenberg)
RAG_DATABASE_URL=postgresql://rai:rai@localhost:5433/rai_rag
RAG_STORAGE_DIR=./storage/rag
RAG_TOP_K=5

# 임베딩: local(키 없이) | openai | litellm. 차원은 vector 컬럼과 일치해야 함
EMBEDDINGS_PROVIDER=local
EMBEDDING_DIM=1536

# 문서 추출(비전 전사). DOC_PARSE_MODEL 이 비어 있으면 비전 비활성(텍스트만)
DOC_PARSE_MODEL=
DOC_PARSE_VISION_MODE=auto
DOC_PARSE_MAX_PAGES=30
DOC_PARSE_TIMEOUT_MS=60000

# Office(docx/pptx/xlsx 등) → PDF 변환 (gotenberg). 비어 있으면 Office 변환 비활성
GOTENBERG_BASE_URL=http://localhost:13012
